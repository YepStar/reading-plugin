{
  "id": "xbiqugu",
  "name": "书香小说",
  "type": "html",
  "baseUrl": "http://www.xbiqugu.net/",
  "enabled": true,
  "search": {
    "url": "http://www.xbiqugu.net/modules/article/waps.php?searchkey=${key}",
    "dataPath": "",
    "listSelector": ".grid tr:not(:first-child)",
    "titleSelector": "a",
    "urlSelector": "a"
  },
  "catalog": {
    "url": "${bookUrl}",
    "dataPath": "",
    "listSelector": "#list dl dd",
    "titleSelector": "a",
    "urlSelector": "a",
    "itemIdField": "",
    "itemTitleField": "",
    "itemUrlField": ""
  },
  "content": {
    "url": "${chapterUrl}",
    "dataPath": "",
