<idea-plugin>
    <id>com.reader.jetbrains</id>
    <name>Reader-plugin-yip</name>
    <version>0.1.0</version>
    <vendor>Reader</vendor>
    <idea-version since-build="242"/>

    <description><![CDATA[
        <p>Native editor reader for local TXT/EPUB files and cleaned web novel pages.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.reader.jetbrains.state.ReaderStateService"/>
        <toolWindow id="Reader-plugin-yip"
                    anchor="right"
                    icon="AllIcons.General.Balloon"
                    factoryClass="com.reader.jetbrains.ui.ReaderToolWindowFactory"/>
    </extensions>

    <actions>
        <group id="reader.group.Main" text="Reader-plugin-yip" popup="true" icon="AllIcons.General.Balloon">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </group>

        <action id="reader.OpenLocalBook"
                class="com.reader.jetbrains.actions.OpenLocalBookAction"
                text="打开本地 TXT / EPUB"
                description="打开 TXT 或 EPUB 并按章节正则拆分"
                icon="AllIcons.Nodes.Folder">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift O"/>
        </action>

        <action id="reader.ToggleNativeReader"
                class="com.reader.jetbrains.actions.ToggleNativeReaderAction"
                text="显示/隐藏原生提示层"
                description="用同一个快捷键切换编辑器内阅读浮层"
                icon="AllIcons.General.Balloon">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift R"/>
        </action>

        <action id="reader.OpenToc"
                class="com.reader.jetbrains.actions.OpenTocAction"
                text="打开目录"
                description="打开章节目录并跳转"
                icon="AllIcons.General.InlineVariablesHover">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift T"/>
        </action>

        <action id="reader.NextChapter"
                class="com.reader.jetbrains.actions.NextChapterAction"
                text="下一章"
                description="切换到下一章"
                icon="AllIcons.Actions.Play_last">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift N"/>
        </action>

        <action id="reader.ToggleAutoNextChapter"
                class="com.reader.jetbrains.actions.ToggleAutoNextChapterAction"
                text="自动下一章 开/关"
                description="启动或停止自动切换章节"
                icon="AllIcons.Actions.Execute">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift A"/>
        </action>

        <action id="reader.OpenPlatformBrowser"
                class="com.reader.jetbrains.actions.OpenPlatformBrowserAction"
                text="平台网页登录"
                description="打开番茄、起点、微信读书或自定义平台页面"
                icon="AllIcons.General.Balloon">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift B"/>
        </action>

        <action id="reader.OpenWebReader"
                class="com.reader.jetbrains.actions.OpenWebReaderAction"
                text="网页正文提取"
                description="加载第三方小说网页并提取正文"
                icon="AllIcons.Actions.SearchWithHistory">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift W"/>
        </action>

        <group id="reader.group.EditorPopup" text="Reader-plugin-yip" popup="true" icon="AllIcons.General.Balloon">
            <reference id="reader.ToggleNativeReader"/>
            <reference id="reader.OpenToc"/>
            <separator/>
            <reference id="reader.NextChapter"/>
            <reference id="reader.ToggleAutoNextChapter"/>
            <separator/>
            <reference id="reader.OpenLocalBook"/>
            <reference id="reader.OpenPlatformBrowser"/>
            <reference id="reader.OpenWebReader"/>
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </group>

        <group id="reader.group.Tools">
            <reference id="reader.OpenLocalBook"/>
            <reference id="reader.ToggleNativeReader"/>
            <reference id="reader.OpenToc"/>
            <reference id="reader.NextChapter"/>
            <reference id="reader.ToggleAutoNextChapter"/>
            <separator/>
            <reference id="reader.OpenPlatformBrowser"/>
            <reference id="reader.OpenWebReader"/>
            <add-to-group group-id="reader.group.Main"/>
        </group>
    </actions>
</idea-plugin>
