<idea-plugin>
    <id>com.reader.jetbrains</id>
    <name>Reader Yip</name>
    <version>0.1.2</version>
    <vendor>Reader</vendor>
    <idea-version since-build="242"/>

    <description><![CDATA[
        <p>Reader Yip is a lightweight reading utility for JetBrains IDEs. It provides an editor-native reading hint for local TXT and EPUB files, configurable chapter splitting, table-of-contents navigation, persisted reading progress, web text extraction, compact platform browser popups, and configurable online book sources.</p>
        <p>This plugin is inspired by W-Reader and focuses on local user-controlled reading workflows. Users are responsible for ensuring that any websites, book sources, and content they access comply with applicable laws and platform terms. The plugin does not bundle, host, or distribute novel content.</p>
    ]]></description>

    <change-notes><![CDATA[
        <p>清理了废弃的接口。</p>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.reader.jetbrains.settings.ReaderSettingsService"/>
        <applicationConfigurable parentId="tools"
                                 instance="com.reader.jetbrains.settings.ReaderSettingsConfigurable"
                                 id="reader.yip.settings"
                                 displayName="Reader Yip"/>
        <projectService serviceImplementation="com.reader.jetbrains.state.ReaderStateService"/>
        <projectService serviceImplementation="com.reader.jetbrains.sources.BookSourceService"/>
        <toolWindow id="Reader Yip"
                    anchor="right"
                    icon="AllIcons.General.Balloon"
                    factoryClass="com.reader.jetbrains.ui.ReaderToolWindowFactory"/>
    </extensions>

    <actions>
        <group id="reader.group.Main" text="Reader Yip" popup="true" icon="AllIcons.General.Balloon">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </group>

        <action id="reader.OpenLocalBook"
                class="com.reader.jetbrains.actions.OpenLocalBookAction"
                text="打开本地 TXT / EPUB"
                description="打开 TXT 或 EPUB 并按章节正则拆分"
                icon="AllIcons.Nodes.Folder">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift O"/>
        </action>

        <action id="reader.ToggleNativeReader"
                class="com.reader.jetbrains.actions.ToggleNativeReaderAction"
                text="显示/隐藏原生提示层"
                description="用同一个快捷键切换编辑器内阅读浮层"
                icon="AllIcons.General.Balloon">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift R"/>
        </action>

        <action id="reader.OpenToc"
                class="com.reader.jetbrains.actions.OpenTocAction"
                text="打开目录"
                description="打开章节目录并跳转"
                icon="AllIcons.General.InlineVariablesHover">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift T"/>
        </action>

        <action id="reader.NextChapter"
                class="com.reader.jetbrains.actions.NextChapterAction"
                text="下一章"
                description="切换到下一章"
                icon="AllIcons.Actions.Play_last">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift N"/>
        </action>

        <action id="reader.PreviousChapter"
                class="com.reader.jetbrains.actions.PreviousChapterAction"
                text="上一章"
                description="切换到上一章"
                icon="AllIcons.Actions.Play_first">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift P"/>
        </action>

        <action id="reader.ToggleAutoNextChapter"
                class="com.reader.jetbrains.actions.ToggleAutoNextChapterAction"
                text="自动下一章 开/关"
                description="启动或停止自动切换章节"
                icon="AllIcons.Actions.Execute">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift A"/>
        </action>

        <action id="reader.OpenPlatformBrowser"
                class="com.reader.jetbrains.actions.OpenPlatformBrowserAction"
                text="平台网页浮窗"
                description="打开番茄、起点、微信读书或自定义平台页面；不导入页面内容"
                icon="AllIcons.General.Balloon">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift B"/>
        </action>

        <action id="reader.OpenWebReader"
                class="com.reader.jetbrains.actions.OpenWebReaderAction"
                text="网页正文提取"
                description="加载第三方小说网页并提取正文"
                icon="AllIcons.Actions.SearchWithHistory">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift W"/>
        </action>

        <action id="reader.SearchOnlineBook"
                class="com.reader.jetbrains.actions.SearchOnlineBookAction"
                text="在线书源搜索"
                description="使用内置或自定义书源搜索小说并导入原生提示层"
                icon="AllIcons.Actions.Search">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift S"/>
        </action>

        <action id="reader.ManageBookSources"
                class="com.reader.jetbrains.actions.ManageBookSourcesAction"
                text="书源管理"
                description="启用、编辑、删除、重置在线小说书源"
                icon="AllIcons.General.Settings">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift M"/>
        </action>

        <group id="reader.group.EditorPopup" text="Reader Yip" popup="true" icon="AllIcons.General.Balloon">
            <reference id="reader.ToggleNativeReader"/>
            <reference id="reader.OpenToc"/>
            <separator/>
            <reference id="reader.PreviousChapter"/>
            <reference id="reader.NextChapter"/>
            <reference id="reader.ToggleAutoNextChapter"/>
            <separator/>
            <reference id="reader.OpenLocalBook"/>
            <reference id="reader.SearchOnlineBook"/>
            <reference id="reader.ManageBookSources"/>
            <reference id="reader.OpenPlatformBrowser"/>
            <reference id="reader.OpenWebReader"/>
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </group>

        <group id="reader.group.Tools">
            <reference id="reader.OpenLocalBook"/>
            <reference id="reader.ToggleNativeReader"/>
            <reference id="reader.OpenToc"/>
            <reference id="reader.PreviousChapter"/>
            <reference id="reader.NextChapter"/>
            <reference id="reader.ToggleAutoNextChapter"/>
            <separator/>
            <reference id="reader.OpenPlatformBrowser"/>
            <reference id="reader.OpenWebReader"/>
            <separator/>
            <reference id="reader.SearchOnlineBook"/>
            <reference id="reader.ManageBookSources"/>
            <add-to-group group-id="reader.group.Main"/>
        </group>
    </actions>
</idea-plugin>
